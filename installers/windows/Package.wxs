<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
  xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="prempti"
           Manufacturer="Falco Authors"
           Version="$(var.ProductVersion)"
           ProductCode="$(var.ProductCode)"
           UpgradeCode="A9AC2103-193A-4D6F-91D4-847BEC23DAB3"
           Scope="perUser">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Prempti is already installed."
            AllowSameVersionUpgrades="yes" />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Complete" Title="prempti" Level="1">
      <ComponentGroupRef Id="BinFiles" />
      <ComponentGroupRef Id="ShareFiles" />
      <ComponentGroupRef Id="RulesDefaultFiles" />
      <ComponentGroupRef Id="RulesSeenFile" />
      <ComponentGroupRef Id="RulesUserDir" />
      <ComponentGroupRef Id="ScriptFiles" />
      <ComponentGroupRef Id="RuntimeDirs" />
      <ComponentGroupRef Id="InstallDirRegistration" />
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />

    <!-- Persist INSTALLDIR to HKCU at install time and read it back on
         every subsequent MSI invocation. Without this, MSI defaults
         INSTALLDIR at uninstall/upgrade time to the compiled-in value,
         so a user who chose a custom path via WixUI_InstallDir would
         see uninstall clean the wrong location and leave the real
         install orphaned. `Secure="yes"` is required so the per-machine
         property survives the sandbox boundary of deferred custom
         actions. -->
    <Property Id="INSTALLDIR" Secure="yes">
      <RegistrySearch Id="InstallDirSearch"
                      Root="HKCU"
                      Key="Software\FalcoAuthors\prempti"
                      Name="InstallDir"
                      Type="directory" />
    </Property>

    <!-- Run post-install setup at the end of MSI install so double-clicking
         the MSI is sufficient for a working installation. Pass
         -Prefix "[INSTALLDIR]." so a custom install path picked via
         WixUI_InstallDir propagates through to config, hook command, Run
         key and the one-shot service start. The trailing "." sentinel is
         there because MSI always renders INSTALLDIR with a trailing "\",
         which would be parsed as an escape of the closing quote by
         PowerShell's argv parser ("\\" ->  "); the script trims "\" and
         "." from the end. -->
    <CustomAction Id="SetRunPostInstallCmdLine"
                  Property="RunPostInstall"
                  Value='"[System64Folder]WindowsPowerShell\v1.0\powershell.exe" -NoProfile -ExecutionPolicy Bypass -File "[#PostInstallScriptFile]" -Prefix "[INSTALLDIR]."' />

    <CustomAction Id="RunPostInstall"
                  BinaryRef="$(var.UtilCABinaryRef)"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="check" />

    <!-- Run pre-uninstall cleanup at the start of MSI uninstall so Apps &
         Features / msiexec /x both stop the service, remove the Claude Code
         hook and the Run-key entry, and clean up the user PATH BEFORE the
         script file itself is removed by RemoveFiles. -Prefix matches the
         location chosen at install time so cleanup targets the right files.
         Return="ignore" so a failure does not block the uninstall — the
         worst case is a stale hook, which is no worse than skipping the CA
         entirely. -->
    <CustomAction Id="SetRunUninstallCmdLine"
                  Property="RunUninstall"
                  Value='"[System64Folder]WindowsPowerShell\v1.0\powershell.exe" -NoProfile -ExecutionPolicy Bypass -File "[#UninstallScriptFile]" -Prefix "[INSTALLDIR]."' />

    <CustomAction Id="RunUninstall"
                  BinaryRef="$(var.UtilCABinaryRef)"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="SetRunPostInstallCmdLine" After="InstallFiles" Condition="NOT Installed AND NOT REMOVE" />
      <Custom Action="RunPostInstall" After="SetRunPostInstallCmdLine" Condition="NOT Installed AND NOT REMOVE" />
      <Custom Action="SetRunUninstallCmdLine" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="RunUninstall" After="SetRunUninstallCmdLine" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>
  </Package>

  <!-- Directory layout under %LOCALAPPDATA%\prempti\ -->
  <Fragment>
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLDIR" Name="prempti">
        <Directory Id="BINDIR" Name="bin" />
        <Directory Id="SHAREDIR" Name="share" />
        <Directory Id="CONFIGDIR" Name="config" />
        <Directory Id="RULESDIR" Name="rules">
          <Directory Id="RULESDEFAULTDIR" Name="default" />
          <Directory Id="RULESUSERDIR" Name="user" />
        </Directory>
        <Directory Id="SCRIPTSDIR" Name="scripts" />
        <Directory Id="RUNDIR" Name="run" />
        <Directory Id="LOGDIR" Name="log" />
      </Directory>
    </StandardDirectory>
  </Fragment>

  <!-- Binaries -->
  <Fragment>
    <ComponentGroup Id="BinFiles" Directory="BINDIR">
      <Component>
        <File Source="$(var.StageDir)\bin\falco.exe" />
      </Component>
      <Component>
        <File Source="$(var.StageDir)\bin\claude-interceptor.exe" />
      </Component>
      <Component>
        <File Source="$(var.StageDir)\bin\codex-interceptor.exe" />
      </Component>
      <Component>
        <File Source="$(var.StageDir)\bin\premptictl.exe" />
      </Component>
      <Component>
        <File Source="$(var.StageDir)\bin\prempti-launcher.ps1" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Plugin shared library -->
  <Fragment>
    <ComponentGroup Id="ShareFiles" Directory="SHAREDIR">
      <Component>
        <File Source="$(var.StageDir)\share\coding_agent.dll" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Default rules -->
  <Fragment>
    <ComponentGroup Id="RulesDefaultFiles" Directory="RULESDEFAULTDIR">
      <Component>
        <File Source="$(var.StageDir)\rules\default\coding_agents_rules.yaml" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Seen rule (loaded last) -->
  <Fragment>
    <ComponentGroup Id="RulesSeenFile" Directory="RULESDIR">
      <Component>
        <File Source="$(var.StageDir)\rules\seen.yaml" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- User rules directory (preserved on upgrade) -->
  <Fragment>
    <ComponentGroup Id="RulesUserDir" Directory="RULESUSERDIR">
      <Component Id="RulesUserDirComp" Guid="D1E2F3A4-B5C6-7890-ABCD-EF1234567890">
        <CreateFolder />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Install scripts -->
  <Fragment>
    <ComponentGroup Id="ScriptFiles" Directory="SCRIPTSDIR">
      <Component>
        <File Id="PostInstallScriptFile" Source="$(var.StageDir)\scripts\postinstall.ps1" />
      </Component>
      <Component>
        <File Id="UninstallScriptFile" Source="$(var.StageDir)\scripts\uninstall.ps1" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Runtime directories (run/, log/) -->
  <Fragment>
    <ComponentGroup Id="RuntimeDirs">
      <Component Id="RunDirComp" Guid="E2F3A4B5-C6D7-8901-BCDE-F12345678902" Directory="RUNDIR">
        <CreateFolder />
      </Component>
      <Component Id="LogDirComp" Guid="F3A4B5C6-D7E8-9012-CDEF-012345678903" Directory="LOGDIR">
        <CreateFolder />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Persisted INSTALLDIR so uninstall / upgrade reads the actual install
       location chosen by the user. Paired with the Property@INSTALLDIR
       RegistrySearch above. -->
  <Fragment>
    <ComponentGroup Id="InstallDirRegistration" Directory="INSTALLDIR">
      <Component Id="InstallDirRegistrationComp" Guid="A4B5C6D7-E8F9-0123-4567-89ABCDEF0004">
        <RegistryKey Root="HKCU" Key="Software\FalcoAuthors\prempti">
          <RegistryValue Type="string" Name="InstallDir" Value="[INSTALLDIR]" KeyPath="yes" />
        </RegistryKey>
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
