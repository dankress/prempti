diff --git a/userspace/falco/CMakeLists.txt b/userspace/falco/CMakeLists.txt
index 72b1629..aaa58bf 100644
--- a/userspace/falco/CMakeLists.txt
+++ b/userspace/falco/CMakeLists.txt
@@ -92,6 +92,14 @@ if(BUILD_HTTP_OUTPUT)
 	endif()
 
 	list(APPEND FALCO_LIBRARIES "${CURL_LIBRARIES}")
+
+	# HTTP output on Windows (Prempti)
+	# Static vcpkg libcurl + curl_global_init() pull in Winsock (WSAStartup); the
+	# ${CURL_LIBRARIES} variable from find_package(CURL) does not reliably propagate
+	# the ws2_32 system dependency for a static link, so link it explicitly.
+	if(WIN32)
+		list(APPEND FALCO_LIBRARIES ws2_32)
+	endif()
 endif()
 
 if(NOT EMSCRIPTEN AND NOT MINIMAL_BUILD)
diff --git a/userspace/falco/outputs_http.cpp b/userspace/falco/outputs_http.cpp
index 47d2e39..d4a7f5d 100644
--- a/userspace/falco/outputs_http.cpp
+++ b/userspace/falco/outputs_http.cpp
@@ -72,6 +72,14 @@ bool falco::outputs::output_http::init(const config &oc,
 	CHECK_RES(curl_easy_setopt(m_curl, CURLOPT_USERAGENT, m_oc.options["user_agent"].c_str()));
 	CHECK_RES(curl_easy_setopt(m_curl, CURLOPT_POSTFIELDSIZE, -1L));
 
+#ifdef _WIN32
+	// HTTP output on Windows (Prempti)
+	// Bypass system/environment proxy settings for localhost alert delivery.
+	// CHECK_RES tolerates CURLE_NOT_BUILT_IN, so a curl built without proxy
+	// support (e.g. the SChannel backend) treats this as a harmless no-op.
+	CHECK_RES(curl_easy_setopt(m_curl, CURLOPT_NOPROXY, "*"));
+#endif
+
 	if(m_oc.options["insecure"] == std::string("true")) {
 		CHECK_RES(curl_easy_setopt(m_curl, CURLOPT_SSL_VERIFYPEER, 0L));
 		CHECK_RES(curl_easy_setopt(m_curl, CURLOPT_SSL_VERIFYHOST, 0L));
