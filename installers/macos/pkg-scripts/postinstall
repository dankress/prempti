#!/bin/bash
# SPDX-License-Identifier: Apache-2.0
#
# postinstall — Run after .pkg installs files to ~/.coding-agents-kit/
#
# Arguments from macOS Installer:
#   $1 = package path
#   $2 = install location (e.g., /Users/username for user-domain installs)
#   $3 = target volume
#   $4 = root directory for the system

INSTALL_LOCATION="$2"
PREFIX="${INSTALL_LOCATION}/.coding-agents-kit"
USER_HOME="${INSTALL_LOCATION}"

# ---------------------------------------------------------------------------
# Render launchd templates
# ---------------------------------------------------------------------------

PLIST_DIR="${USER_HOME}/Library/LaunchAgents"
PLIST_FILE="${PLIST_DIR}/dev.falcosecurity.coding-agents-kit.plist"

mkdir -p "$PLIST_DIR"
mkdir -p "$PREFIX/log"

# Render plist with actual prefix and HOME.
sed -e "s|@PREFIX@|${PREFIX}|g" -e "s|@HOME@|${USER_HOME}|g" \
    "$PREFIX/launchd/dev.falcosecurity.coding-agents-kit.plist" \
    > "$PLIST_FILE"

# Render launcher script.
sed "s|@PREFIX@|${PREFIX}|g" \
    "$PREFIX/launchd/coding-agents-kit-launcher.sh" \
    > "$PREFIX/bin/coding-agents-kit-launcher.sh"
chmod 755 "$PREFIX/bin/coding-agents-kit-launcher.sh"

# ---------------------------------------------------------------------------
# Create user rules directory (if not exists)
# ---------------------------------------------------------------------------

if [[ ! -d "$PREFIX/rules/user" ]]; then
    mkdir -p "$PREFIX/rules/user"
fi

# ---------------------------------------------------------------------------
# Start service
# ---------------------------------------------------------------------------
#
# Postinstall runs either:
#   - as root, when the user invokes `installer` via sudo or authenticates in
#     the GUI Installer for a system-scoped component; OR
#   - as the installing user, when the pkg is user-domain (our case, via
#     `enable_currentUserHome="true"`) and the GUI Installer.app or
#     `installer -target CurrentUserHomeDirectory` runs the scripts without
#     elevation.
#
# Only drop privileges via `su` when we are actually root; otherwise run
# `launchctl` directly so the agent is loaded into the current user's session.
# Running `su $OWNER` as a non-root user fails (password prompt) and was
# silently swallowed, leaving the agent unloaded until the next login.

OWNER=$(stat -f '%Su' "$USER_HOME")

if [[ "$(id -u)" -eq 0 && -n "$OWNER" && "$OWNER" != "root" ]]; then
    su "$OWNER" -c "launchctl load '$PLIST_FILE'" 2>/dev/null || true
else
    launchctl load "$PLIST_FILE" 2>/dev/null || true
fi

exit 0
