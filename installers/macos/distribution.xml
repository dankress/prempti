<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Prempti</title>
    <welcome file="welcome.html"/>
    <conclusion file="conclusion.html"/>
    <domains enable_currentUserHome="true" enable_localSystem="false" enable_anywhere="false"/>
    <options customize="never" require-scripts="false" hostArchitectures="@HOST_ARCHS@"/>
    <pkg-ref id="dev.falcosecurity.prempti"/>
    <choices-outline>
        <line choice="default">
            <line choice="dev.falcosecurity.prempti"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="dev.falcosecurity.prempti" visible="false">
        <pkg-ref id="dev.falcosecurity.prempti"/>
    </choice>
    <pkg-ref id="dev.falcosecurity.prempti" version="@VERSION@" onConclusion="none">component.pkg</pkg-ref>
</installer-gui-script>
